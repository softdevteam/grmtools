name: Test fixed serialisation format from grmtools section.
yacckind: Original(YaccOriginalActionKind::NoAction)
grammar: |
    %grmtools{serialisation_format: SerialisationFormat::FixedSizeInteger}
    %start Expr
    %avoid_insert 'INT'
    %%
    Expr: Expr '+' Term
        | Term
        ;

    Term: Term '*' Factor
        | Factor
        ;

    Factor: '(' Expr ')'
          | 'INT'
          ;

lexer: |
    %%
    [0-9]+ "INT"
    \+ "+"
    \* "*"
    \( "("
    \) ")"
    [\t ]+ ;
